FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY src/backend ./src/backend

RUN dotnet restore ./src/backend/PropOpsCopilot.Api/PropOpsCopilot.Api.csproj
RUN dotnet publish ./src/backend/PropOpsCopilot.Api/PropOpsCopilot.Api.csproj -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app

ENV ASPNETCORE_URLS=http://+:8080

COPY --from=build /app/publish .

EXPOSE 8080

ENTRYPOINT ["dotnet", "PropOpsCopilot.Api.dll"]
